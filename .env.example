# ============================================================
# TibetPublicOpinionRAG 环境变量模板
# 复制为 .env 并填入真实值: cp .env.example .env
# ============================================================
# 加载位置:
#   - Django:  backend/settings.py → load_dotenv(BASE_DIR.parent / '.env')
#   - Flask:   rerank_service/app.py → load_dotenv(PROJECT_ROOT / '.env')
# ============================================================

# -------------------------------------------------------
# 🔑 API Key（必填）
# -------------------------------------------------------
# 阿里百炼 DashScope API Key
# 用途: LLM 生成、多模态嵌入、重排序、流程图 Agent
# 获取: https://dashscope.console.aliyuncs.com/
DASHSCOPE_API_KEY=your_api_key_here

# -------------------------------------------------------
# 🔒 Django 核心
# -------------------------------------------------------
# Django SECRET_KEY（生产环境务必更换为随机字符串）
# 生成方式: uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
# 调试模式（生产环境设为 False）
DEBUG=True

# -------------------------------------------------------
# 🤖 LLM / Agent 模型
# -------------------------------------------------------
# 流程图 Agent 模型名（DashScope OpenAI 兼容模式）
# 可选: qwen-plus / qwen-max / qwen3-omni-flash
FLOW_AGENT_MODEL_NAME=qwen-plus

# 流程图 Agent 最大输入字符数
FLOW_AGENT_MAX_INPUT_CHARS=120000

# 开启大模型思考模式（针对支持思考的本地模型，如 Qwen3 等）
LLM_ENABLE_THINKING=true

# -------------------------------------------------------
# 🎯 重排序
# -------------------------------------------------------
# 重排序模型名（DashScope Rerank API）
RERANK_MODEL_NAME=qwen3-rerank

# 重排序微服务监听地址和端口
RERANK_SERVICE_HOST=127.0.0.1
RERANK_SERVICE_PORT=5001

# Django → Flask 重排序微服务 URL
RERANK_SERVICE_URL=http://127.0.0.1:5001/rerank

# 本地重排序模型设备偏好（仅使用本地 CrossEncoder 时生效）
# cuda / cpu / auto（默认 auto，优先 GPU）
RERANKER_DEVICE=auto

# 送入重排序的候选数量（值越大越准但越慢，留空则动态计算: top_k * 6）
RAG_M_FOR_RERANK=

# -------------------------------------------------------
# 📊 检索阈值（拒答控制）
# -------------------------------------------------------
# RRF 融合分阈值，低于该值视为无相关上下文，拒绝回答
RAG_RELEVANCE_THRESHOLD=0.04
# CrossEncoder 原始分数阈值，低于该值视为无相关上下文
RAG_CE_RELEVANCE_THRESHOLD=0.3

# -------------------------------------------------------
# 🗄️ 向量数据库
# -------------------------------------------------------
# ChromaDB 持久化路径
CHROMA_DB_PATH=./chroma_db

# 多模态向量存储集合名
MULTIMODAL_COLLECTION_NAME=multimodal_documents

# -------------------------------------------------------
# 🖼️ 嵌入 & 编码
# -------------------------------------------------------
# 通义千问多模态嵌入模型
TONGYI_EMBED_MODEL=tongyi-embedding-vision-plus

# 编码批处理大小（每次调用 Embedding API 的条数）
ENCODING_BATCH_SIZE=10

# 本地重排序模型路径（promt 模块使用，默认 BGE-reranker-large）
RAG_RERANKER_MODEL_NAME=./models/bge-reranker-large

# -------------------------------------------------------
# 🧪 预热
# -------------------------------------------------------
# RAG 服务预热开关（true=启动时预热 Chroma/重排序，false=首次查询惰性加载）
RAG_WARMUP_ENABLED=false

# -------------------------------------------------------
# 📁 路径
# -------------------------------------------------------

# -------------------------------------------------------
# 🌐 多语言支持
# -------------------------------------------------------
# 启用多语言分词（支持中文/藏文/英文混合检索）
# true=使用多语言分词器，false=仅使用 jieba 中文分词
MULTILINGUAL_TOKENIZER=true
# 企业用户 Excel 导入文件路径
ENTERPRISE_USERS_EXCEL_PATH=./data/enterprise_users.xlsx
